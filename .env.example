# Autonomous Software Factory - worker-core
# Copy this file to .env and fill in your actual values.
# Then run: wrangler secret put <KEY> < .env

# API Keys (comma-separated for multiple keys)
GOOGLE_AI_KEYS=your_google_ai_key
OPENROUTER_API_KEYS=your_openrouter_key
HUGGINGFACE_API_KEYS=your_huggingface_key
GROQ_API_KEYS=your_groq_key
MISTRAL_API_KEYS=your_mistral_key
GITHUB_TOKENS=your_github_token

# Google Drive (base64-encoded service account JSON)
GDRIVE_CREDENTIALS=your_base64_encoded_credentials

# Google Pay India
GPAY_MERCHANT_ID=your_merchant_id
GPAY_MERCHANT_KEY=your_merchant_key
GPAY_PUBLIC_KEY=your_public_key_pem

# Email (Mailgun)
MAILGUN_API_KEY=your_mailgun_key
MAILGUN_DOMAIN=your_mailgun_domain

# WhatsApp Business
WHATSAPP_API_TOKEN=your_whatsapp_token

# Cloudflare (for auto-deployment)
CLOUDFLARE_API_TOKEN=your_cloudflare_token
CLOUDFLARE_ACCOUNT_ID=your_account_id

# MCP Endpoint Auth
ADMIN_AUTH_TOKEN=your_admin_bearer_token
